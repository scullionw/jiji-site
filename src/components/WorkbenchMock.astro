---
// A faux Jiji window: the jj log graph on the left, a continuous diff on the
// right. Rebuilt from the app's real components (GraphRow, FileDiffCard) and
// driven entirely by the design tokens, so it re-themes with the page.
---

<div class="win" role="img" aria-label="Screenshot of the Jiji workbench: a Jujutsu commit graph beside a file diff.">
  <!-- window chrome -->
  <div class="chrome">
    <span class="lights"><i></i><i></i><i></i></span>
    <span class="title">my-app</span>
    <span class="chrome-right mono">jj</span>
  </div>

  <div class="panes">
    <!-- graph pane -->
    <div class="graph">
      <div class="pane-head">Workbench</div>

      <!-- working copy -->
      <div class="grow hot">
        <span class="gutter">
          <svg viewBox="0 0 50 30" width="50" height="30" aria-hidden="true">
            <path class="rail hot" d="M19 21 V30" />
            <text class="mk-wc" x="19" y="16">@</text>
          </svg>
        </span>
        <span class="cid mono"><b>kp</b>xqlm</span>
        <span class="cdesc">Polish theme switcher cross-fade</span>
        <span class="chips"><span class="chip wc">working copy</span></span>
        <span class="cmeta mono">2m</span>
      </div>

      <div class="grow hot">
        <span class="gutter">
          <svg viewBox="0 0 50 30" width="50" height="30" aria-hidden="true">
            <path class="rail hot" d="M19 0 V9" />
            <path class="rail hot" d="M19 21 V30" />
            <circle class="mk-change hot" cx="19" cy="15" r="4" />
          </svg>
        </span>
        <span class="cid mono"><b>zt</b>wnoq</span>
        <span class="cdesc">Add registration popover to top bar</span>
        <span class="chips"></span>
        <span class="cmeta mono">1h</span>
      </div>

      <div class="grow hot">
        <span class="gutter">
          <svg viewBox="0 0 50 30" width="50" height="30" aria-hidden="true">
            <path class="rail hot" d="M19 0 V9" />
            <path class="rail hot" d="M19 21 V30" />
            <circle class="mk-change hot" cx="19" cy="15" r="4" />
            <path class="rail calm" d="M39 21 V30" />
            <circle class="mk-change calm" cx="39" cy="15" r="4" />
          </svg>
        </span>
        <span class="cid mono"><b>ox</b>vlmp</span>
        <span class="cdesc">Add Polar license module</span>
        <span class="chips"><span class="chip bm">license</span></span>
        <span class="cmeta mono">3h</span>
      </div>

      <div class="grow base">
        <span class="gutter">
          <svg viewBox="0 0 50 30" width="50" height="30" aria-hidden="true">
            <path class="rail hot" d="M19 0 V9" />
            <path class="rail calm" d="M39 0 V9 Q39 15 33 15 H25" />
            <path class="rail base" d="M19 21 V30" />
            <rect class="mk-base" x="15" y="11" width="8" height="8" rx="1.5" transform="rotate(45 19 15)" />
          </svg>
        </span>
        <span class="cid mono"><b>qm</b>rkzt</span>
        <span class="cdesc">Merge pull request #128</span>
        <span class="chips"><span class="chip bm trunk">main</span></span>
        <span class="cmeta mono">1d</span>
      </div>

      <div class="grow base">
        <span class="gutter">
          <svg viewBox="0 0 50 30" width="50" height="30" aria-hidden="true">
            <path class="rail base" d="M19 0 V9" />
            <path class="rail stub" d="M19 21 V30" />
            <rect class="mk-base" x="15" y="11" width="8" height="8" rx="1.5" transform="rotate(45 19 15)" />
          </svg>
        </span>
        <span class="cid mono"><b>ln</b>pqss</span>
        <span class="cdesc">Bump dependencies</span>
        <span class="chips"></span>
        <span class="cmeta mono">1d</span>
      </div>

      <div class="grow elision">
        <span class="gutter">
          <svg viewBox="0 0 50 30" width="50" height="30" aria-hidden="true">
            <path class="rail stub" d="M19 0 V8" />
            <text class="mk-elide" x="19" y="17">⋮</text>
            <path class="rail stub" d="M19 22 V30" />
          </svg>
        </span>
        <span class="cdesc elide-label">47 earlier commits</span>
      </div>
    </div>

    <div class="divider"></div>

    <!-- diff pane -->
    <div class="diff">
      <div class="fhead">
        <svg class="chev open" viewBox="0 0 12 12" aria-hidden="true"><path d="M4 2l4 4-4 4" /></svg>
        <span class="status modified">M</span>
        <span class="fpath mono"><span class="dir">src/lib/state/</span><span class="fname">theme.svelte.ts</span></span>
        <span class="fstats mono"><span class="add">+12</span><span class="del">−3</span></span>
      </div>

      <div class="lines mono">
        <div class="dline"><span class="dno">40</span><span class="dno">40</span><span class="dcode">  const DEFAULT_DARK = "midnight";</span></div>
        <div class="dline"><span class="dno">41</span><span class="dno">41</span><span class="dcode">  const DEFAULT_LIGHT = "paper";</span></div>
        <div class="dline removed"><span class="dno">42</span><span class="dno"></span><span class="dcode">function apply() &#123;</span></div>
        <div class="dline added"><span class="dno"></span><span class="dno">42</span><span class="dcode">function apply(animate: boolean) &#123;</span></div>
        <div class="dline"><span class="dno">43</span><span class="dno">43</span><span class="dcode">  const root = document.documentElement;</span></div>
        <div class="gap"><i></i><span>6 unchanged lines</span><i></i></div>
        <div class="dline"><span class="dno">50</span><span class="dno">50</span><span class="dcode">  theme.resolved = resolvedScheme();</span></div>
        <div class="dline removed"><span class="dno">51</span><span class="dno"></span><span class="dcode">  swap();</span></div>
        <div class="dline added"><span class="dno"></span><span class="dno">51</span><span class="dcode">  if (animate) document.startViewTransition(swap);</span></div>
        <div class="dline added"><span class="dno"></span><span class="dno">52</span><span class="dcode">  else swap();</span></div>
        <div class="dline"><span class="dno">52</span><span class="dno">53</span><span class="dcode">&#125;</span></div>
      </div>

      <div class="fhead collapsed">
        <svg class="chev" viewBox="0 0 12 12" aria-hidden="true"><path d="M4 2l4 4-4 4" /></svg>
        <span class="status added">A</span>
        <span class="fpath mono"><span class="dir">src/lib/</span><span class="fname">license.ts</span></span>
        <span class="fstats mono"><span class="add">+48</span></span>
      </div>
    </div>
  </div>
</div>

<style>
  .win {
    width: 100%;
    border: 1px solid var(--clr-border-1);
    border-radius: var(--radius-xl);
    background: var(--clr-bg-1);
    box-shadow: var(--shadow-3);
    overflow: hidden;
    user-select: none;
  }

  /* ── chrome ── */
  .chrome {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    height: 38px;
    padding: 0 var(--sp-4);
    background: var(--clr-bg-2);
    border-bottom: 1px solid var(--clr-border-2);
  }

  .lights {
    display: inline-flex;
    gap: 7px;
  }

  .lights i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--clr-text-3);
    opacity: 0.55;
  }

  .lights i:first-child {
    background: #e0605c;
    opacity: 0.9;
  }
  .lights i:nth-child(2) {
    background: #d9a04c;
    opacity: 0.9;
  }
  .lights i:nth-child(3) {
    background: #58b47c;
    opacity: 0.9;
  }

  .title {
    flex: 1;
    text-align: center;
    font-size: var(--text-m);
    color: var(--clr-text-2);
    font-weight: 550;
  }

  .chrome-right {
    font-size: var(--text-s);
    color: var(--clr-text-3);
    min-width: 24px;
    text-align: right;
  }

  /* ── panes ── */
  .panes {
    display: flex;
    height: 312px;
  }

  .graph {
    flex: 1 1 46%;
    min-width: 0;
    background: var(--clr-bg-1);
    padding-bottom: var(--sp-2);
    overflow: hidden;
  }

  .divider {
    width: 1px;
    background: var(--clr-border-2);
  }

  .diff {
    flex: 1 1 54%;
    min-width: 0;
    background: var(--clr-bg-1);
    overflow: hidden;
  }

  .pane-head {
    padding: var(--sp-2) var(--sp-3);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--clr-text-3);
  }

  /* ── graph rows (mirrors GraphRow.svelte) ── */
  .grow {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    height: 30px;
    padding-right: var(--sp-3);
  }

  .grow.base {
    background: color-mix(in srgb, var(--clr-bg-0) 40%, transparent);
  }

  .gutter {
    flex-shrink: 0;
    width: 50px;
    height: 30px;
  }

  .gutter svg {
    display: block;
  }

  .rail {
    fill: none;
    stroke-width: 1.5;
  }
  .rail.hot {
    stroke: color-mix(in srgb, var(--clr-accent) 72%, var(--clr-bg-3));
  }
  .rail.calm {
    stroke: color-mix(in srgb, var(--clr-accent) 30%, var(--clr-bg-3));
  }
  .rail.base {
    stroke: color-mix(in srgb, var(--clr-text-3) 55%, var(--clr-bg-3));
  }
  .rail.stub {
    stroke: color-mix(in srgb, var(--clr-text-3) 55%, var(--clr-bg-3));
    stroke-dasharray: 2 3;
  }

  .mk-wc {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    fill: var(--clr-working-copy);
    text-anchor: middle;
    paint-order: stroke;
    stroke: var(--clr-bg-1);
    stroke-width: 3;
  }

  .mk-change {
    fill: var(--clr-bg-1);
    stroke-width: 1.5;
  }
  .mk-change.hot {
    stroke: var(--clr-accent);
  }
  .mk-change.calm {
    stroke: color-mix(in srgb, var(--clr-accent) 45%, var(--clr-text-3));
  }

  .mk-base {
    fill: color-mix(in srgb, var(--clr-text-3) 75%, var(--clr-bg-3));
  }

  .mk-elide {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--clr-text-3);
    text-anchor: middle;
  }

  .cid {
    flex-shrink: 0;
    font-size: var(--text-s);
    color: var(--clr-text-3);
  }
  .cid b {
    color: var(--clr-accent-strong);
    font-weight: 600;
  }
  .base .cid b {
    color: var(--clr-text-2);
  }

  .cdesc {
    flex: 1;
    min-width: 0;
    font-size: var(--text-m);
    color: var(--clr-text-2);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .hot .cdesc {
    color: var(--clr-text-1);
  }
  .base .cdesc {
    color: var(--clr-text-3);
  }
  .elide-label {
    flex: 1;
    font-size: var(--text-s);
    color: var(--clr-text-3);
    font-style: italic;
  }

  .chips {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    height: 16px;
    padding: 0 7px;
    font-size: var(--text-xs);
    border-radius: 999px;
    white-space: nowrap;
  }
  .chip.wc {
    background: var(--clr-working-copy-dim);
    color: var(--clr-working-copy);
  }
  .chip.bm {
    background: var(--clr-bg-3);
    color: var(--clr-text-2);
    border: 1px solid var(--clr-border-2);
  }
  .chip.bm.trunk {
    background: var(--clr-accent-dim);
    border-color: color-mix(in srgb, var(--clr-accent) 30%, transparent);
    color: var(--clr-accent-strong);
  }

  .cmeta {
    flex-shrink: 0;
    font-size: var(--text-xs);
    color: var(--clr-text-3);
  }

  /* ── diff (mirrors FileDiffCard.svelte) ── */
  .fhead {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 6px var(--sp-4) 6px var(--sp-3);
    background: var(--clr-bg-1);
    border-bottom: 1px solid var(--clr-border-2);
    box-shadow: var(--shadow-edge);
  }
  .fhead.collapsed {
    border-top: 1px solid var(--clr-border-2);
  }

  .chev {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    fill: none;
    stroke: var(--clr-text-3);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .chev.open {
    transform: rotate(90deg);
  }

  .status {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    display: grid;
    place-items: center;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
  }
  .status.modified {
    color: var(--clr-warn);
    background: color-mix(in srgb, var(--clr-warn) 12%, transparent);
  }
  .status.added {
    color: var(--clr-ok);
    background: color-mix(in srgb, var(--clr-ok) 12%, transparent);
  }

  .fpath {
    display: flex;
    min-width: 0;
    font-size: var(--text-s);
    white-space: nowrap;
  }
  .dir {
    color: var(--clr-text-3);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .fname {
    color: var(--clr-text-1);
    font-weight: 500;
  }

  .fstats {
    flex-shrink: 0;
    margin-left: auto;
    display: flex;
    gap: var(--sp-2);
    font-size: var(--text-xs);
  }
  .fstats .add {
    color: var(--clr-ok);
  }
  .fstats .del {
    color: var(--clr-danger);
  }

  .lines {
    --row-h: calc(var(--text-code) * var(--lh-code));
    font-size: var(--text-code);
    line-height: var(--lh-code);
    padding: 3px 0;
    overflow: hidden;
  }

  .dline {
    display: grid;
    grid-template-columns: 3ch 3ch 1fr;
    height: var(--row-h);
  }
  .dno {
    text-align: right;
    padding-right: 1ch;
    color: var(--clr-text-3);
    opacity: 0.75;
    font-size: var(--text-xs);
  }
  .dcode {
    white-space: pre;
    padding: 0 var(--sp-3) 0 var(--sp-2);
    color: var(--clr-text-1);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dline.added {
    background: color-mix(in srgb, var(--clr-ok) 15%, transparent);
  }
  .dline.added .dno {
    color: color-mix(in srgb, var(--clr-ok) 85%, var(--clr-text-3));
    opacity: 1;
  }
  .dline.removed {
    background: color-mix(in srgb, var(--clr-danger) 15%, transparent);
  }
  .dline.removed .dno {
    color: color-mix(in srgb, var(--clr-danger) 80%, var(--clr-text-3));
    opacity: 1;
  }

  .gap {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    height: var(--row-h);
    padding: 0 var(--sp-4);
  }
  .gap span {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--clr-text-3);
  }
  .gap i {
    height: 1px;
    flex: 1;
    background: var(--clr-border-2);
  }

  /* On narrow screens the diff gives way, like the app's responsive graph. */
  @media (max-width: 760px) {
    .divider,
    .diff {
      display: none;
    }
    .graph {
      flex-basis: 100%;
    }
    .panes {
      height: auto;
    }
  }
</style>
