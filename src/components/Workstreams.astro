---
// Spotlight on the Workstreams / Focus view. The mock is rebuilt from the
// app's FocusView + SiblingLane components: one workstream's stack on its
// trunk base, with other workstreams listed beside it. Token-driven, so it
// re-themes with the page.
---

<section class="section workstreams" id="workstreams">
  <div class="container grid">
    <div class="copy">
      <p class="eyebrow">Workstreams</p>
      <h2>Made for stacked work.</h2>
      <p>
        Modern teams ship in stacks — small, dependent changes that land in
        order. Jiji treats that as a first-class way to work. Every mutable line
        of work is a <strong>workstream</strong>: an ordered chain of changes,
        optionally published through a bookmark.
      </p>
      <p>
        Flip the workbench from the full graph to <strong>Focus</strong> and you
        get one workstream at a time — its chain sitting on the trunk it's based
        on, with your other stacks a click away. The calm, stack-centric view,
        without leaving jj's model behind.
      </p>

      <ul class="points">
        <li>
          <span class="kbd">G</span> / <span class="kbd">W</span>
          <span>Two views, one selection — the whole tree, or a single stack. Your choice is remembered.</span>
        </li>
        <li>
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M5 3h6v10l-3-2-3 2V3z" /></svg>
          <span>Each stack shows its publish bookmark and how far it sits behind trunk.</span>
        </li>
        <li>
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h8M8 4l4 4-4 4" /></svg>
          <span>Jump focus between stacks instantly — the diff and inspector follow along.</span>
        </li>
      </ul>

      <p class="next"><span class="next-k">Next</span> Submit &amp; land each workstream as a PR stack — the view you already work in becomes the way you ship.</p>
    </div>

    <!-- Focus-view mock -->
    <div class="mockwrap">
      <div class="focuswin" role="img" aria-label="Screenshot of Jiji's Focus view: one workstream's stack of changes on its trunk base, with other workstreams listed below.">
        <div class="pane-head">
          <span class="pane-label">3 workstreams</span>
          <div class="toggle" aria-hidden="true">
            <span class="tg">Graph</span>
            <span class="tg active">Focus</span>
          </div>
        </div>

        <div class="focus-body">
          <section class="lane">
            <header class="lane-head">
              <h3>Theme switcher polish</h3>
              <span class="bm-chip">
                <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M5 3h6v10l-3-2-3 2V3z" /></svg>
                feat/theme-switcher
              </span>
              <span class="lane-meta">3 changes · <span class="behind">2 behind trunk</span></span>
            </header>

            <div class="rows">
              <div class="grow hot">
                <span class="gutter"><svg viewBox="0 0 44 30" width="44" height="30" aria-hidden="true"><path class="rail hot" d="M17 21 V30" /><text class="mk-wc" x="17" y="16">@</text></svg></span>
                <span class="cid mono"><b>vq</b>nxlk</span>
                <span class="cdesc">Animate palette cross-fade</span>
                <span class="wc-chip">working copy</span>
              </div>
              <div class="grow hot">
                <span class="gutter"><svg viewBox="0 0 44 30" width="44" height="30" aria-hidden="true"><path class="rail hot" d="M17 0 V9" /><path class="rail hot" d="M17 21 V30" /><circle class="mk-change hot" cx="17" cy="15" r="4" /></svg></span>
                <span class="cid mono"><b>ws</b>polz</span>
                <span class="cdesc">Persist theme choice to disk</span>
              </div>
              <div class="grow hot">
                <span class="gutter"><svg viewBox="0 0 44 30" width="44" height="30" aria-hidden="true"><path class="rail hot" d="M17 0 V9" /><path class="rail hot" d="M17 21 V30" /><circle class="mk-change hot" cx="17" cy="15" r="4" /></svg></span>
                <span class="cid mono"><b>tk</b>mzqr</span>
                <span class="cdesc">Add ten-theme registry</span>
              </div>
            </div>

            <div class="base-zone">
              <div class="zone-caption">
                <span class="zone-gutter"><i class="zone-rail"></i></span>
                <span class="zone-label">based on</span>
              </div>
              <div class="grow base">
                <span class="gutter"><svg viewBox="0 0 44 30" width="44" height="30" aria-hidden="true"><path class="rail base" d="M17 0 V9" /><path class="rail stub" d="M17 21 V30" /><rect class="mk-base" x="13" y="11" width="8" height="8" rx="1.5" transform="rotate(45 17 15)" /></svg></span>
                <span class="cid mono"><b>qm</b>rkzt</span>
                <span class="cdesc">Merge pull request #128</span>
                <span class="bm-chip trunk">main</span>
              </div>
              <p class="behind-foot">main is 2 changes ahead of this base</p>
            </div>
          </section>

          <h4 class="aside-label">Other workstreams</h4>
          <div class="siblings">
            <button class="sibling" type="button" tabindex="-1" aria-hidden="true">
              <span class="mini"><i class="dot"></i><i class="dot"></i></span>
              <span class="stext">
                <span class="sl1"><span class="sname">License registration</span><span class="bm-chip">feat/license</span></span>
                <span class="smeta">2 changes</span>
              </span>
            </button>
            <button class="sibling" type="button" tabindex="-1" aria-hidden="true">
              <span class="mini"><i class="dot"></i></span>
              <span class="stext">
                <span class="sl1"><span class="sname">Docs refresh</span></span>
                <span class="smeta">1 change · 5 behind trunk</span>
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .workstreams {
    border-block: 1px solid var(--clr-border-2);
    background: var(--clr-bg-1);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }

  .copy h2 {
    font-size: var(--fs-h2);
    margin-top: var(--sp-3);
  }

  .copy > p {
    margin-top: var(--sp-4);
    color: var(--clr-text-2);
    font-size: 1.02rem;
  }

  .copy strong {
    color: var(--clr-text-1);
    font-weight: 600;
  }

  .points {
    list-style: none;
    margin-top: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .points li {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    color: var(--clr-text-2);
    font-size: 0.98rem;
  }

  .points svg {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 3px;
    fill: none;
    stroke: var(--clr-accent-strong);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .points .kbd {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--clr-text-2);
    background: var(--clr-bg-3);
    border: 1px solid var(--clr-border-1);
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 1px 5px;
    flex-shrink: 0;
  }

  .next {
    margin-top: var(--sp-5);
    padding: var(--sp-3) var(--sp-4);
    background: var(--clr-accent-dim);
    border-radius: var(--radius-m);
    font-size: 0.95rem;
    color: var(--clr-text-2);
  }

  .next-k {
    font-weight: 700;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--clr-accent-strong);
    margin-right: var(--sp-2);
  }

  /* ── focus-view mock ── */
  .mockwrap {
    perspective: 1600px;
  }

  .focuswin {
    border: 1px solid var(--clr-border-1);
    border-radius: var(--radius-xl);
    background: var(--clr-bg-1);
    box-shadow: var(--shadow-3);
    overflow: hidden;
    user-select: none;
  }

  .pane-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 38px;
    padding: 0 var(--sp-3);
    border-bottom: 1px solid var(--clr-border-2);
    background: var(--clr-bg-2);
  }

  .pane-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--clr-text-3);
  }

  .toggle {
    display: inline-flex;
    border: 1px solid var(--clr-border-2);
    border-radius: 999px;
    overflow: hidden;
  }

  .tg {
    padding: 3px 11px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--clr-text-3);
  }

  .tg + .tg {
    border-left: 1px solid var(--clr-border-2);
  }

  .tg.active {
    background: var(--clr-bg-3);
    color: var(--clr-text-1);
  }

  .focus-body {
    padding: var(--sp-4);
  }

  .lane {
    background: var(--clr-bg-2);
    border: 1px solid var(--clr-border-2);
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-1);
    overflow: hidden;
  }

  .lane-head {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-3);
    border-bottom: 1px solid var(--clr-border-2);
  }

  .lane-head h3 {
    font-size: var(--text-l);
    font-weight: 600;
    letter-spacing: -0.2px;
  }

  .lane-meta {
    margin-left: auto;
    flex-shrink: 0;
    font-size: var(--text-s);
    color: var(--clr-text-3);
  }

  .lane-meta .behind {
    color: var(--clr-warn);
  }

  .rows {
    padding: var(--sp-2) 0;
  }

  /* graph rows (single column) */
  .grow {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    height: 30px;
    padding-right: var(--sp-3);
  }

  .gutter {
    flex-shrink: 0;
    width: 44px;
    height: 30px;
  }

  .gutter svg {
    display: block;
  }

  .rail {
    fill: none;
    stroke-width: 1.5;
  }
  .rail.hot {
    stroke: color-mix(in srgb, var(--clr-accent) 72%, var(--clr-bg-3));
  }
  .rail.base {
    stroke: color-mix(in srgb, var(--clr-text-3) 55%, var(--clr-bg-3));
  }
  .rail.stub {
    stroke: color-mix(in srgb, var(--clr-text-3) 55%, var(--clr-bg-3));
    stroke-dasharray: 2 3;
  }

  .mk-wc {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    fill: var(--clr-working-copy);
    text-anchor: middle;
    paint-order: stroke;
    stroke: var(--clr-bg-2);
    stroke-width: 3;
  }

  .mk-change {
    fill: var(--clr-bg-2);
    stroke-width: 1.5;
  }
  .mk-change.hot {
    stroke: var(--clr-accent);
  }

  .mk-base {
    fill: color-mix(in srgb, var(--clr-text-3) 75%, var(--clr-bg-3));
  }

  .cid {
    flex-shrink: 0;
    font-size: var(--text-s);
    color: var(--clr-text-3);
  }
  .cid b {
    color: var(--clr-accent-strong);
    font-weight: 600;
  }
  .base .cid b {
    color: var(--clr-text-2);
  }

  .cdesc {
    flex: 1;
    min-width: 0;
    font-size: var(--text-m);
    color: var(--clr-text-1);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .base .cdesc {
    color: var(--clr-text-3);
  }

  .bm-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    height: 18px;
    padding: 0 8px;
    font-size: var(--text-xs);
    border-radius: 999px;
    background: var(--clr-bg-3);
    color: var(--clr-text-2);
    border: 1px solid var(--clr-border-2);
    white-space: nowrap;
  }

  .bm-chip svg {
    width: 10px;
    height: 10px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linejoin: round;
  }

  .bm-chip.trunk {
    background: var(--clr-accent-dim);
    border-color: color-mix(in srgb, var(--clr-accent) 30%, transparent);
    color: var(--clr-accent-strong);
  }

  .wc-chip {
    flex-shrink: 0;
    height: 16px;
    display: inline-flex;
    align-items: center;
    padding: 0 7px;
    font-size: var(--text-xs);
    border-radius: 999px;
    background: var(--clr-working-copy-dim);
    color: var(--clr-working-copy);
  }

  /* recessed trunk base */
  .base-zone {
    background: color-mix(in srgb, var(--clr-bg-1) 55%, var(--clr-bg-2));
    border-top: 1px solid var(--clr-border-2);
    padding-bottom: var(--sp-2);
  }

  .zone-caption {
    display: flex;
    align-items: center;
    height: 26px;
  }

  .zone-gutter {
    position: relative;
    align-self: stretch;
    width: 44px;
    flex-shrink: 0;
  }

  .zone-rail {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 16px;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      var(--clr-border-1) 0 4px,
      transparent 4px 8px
    );
  }

  .zone-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--clr-text-3);
  }

  .behind-foot {
    padding: 2px var(--sp-4) 2px 44px;
    font-size: var(--text-s);
    color: var(--clr-warn);
  }

  .aside-label {
    margin: var(--sp-5) 0 var(--sp-2);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--clr-text-3);
  }

  .siblings {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .sibling {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    width: 100%;
    text-align: left;
    padding: var(--sp-2) var(--sp-3);
    border: 1px solid var(--clr-border-2);
    border-radius: var(--radius-l);
    cursor: default;
  }

  .mini {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    flex-shrink: 0;
    width: 14px;
  }

  .mini .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--clr-accent) 55%, var(--clr-bg-3));
  }

  .stext {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sl1 {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .sname {
    font-size: var(--text-m);
    font-weight: 500;
    color: var(--clr-text-2);
  }

  .smeta {
    font-size: var(--text-xs);
    color: var(--clr-text-3);
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
      gap: var(--sp-8);
    }
    .mockwrap {
      order: -1;
    }
  }
</style>
