---
import Logo from "./Logo.astro";
import {
  DOWNLOAD_URL,
  GITHUB_URL,
  RELEASES_URL,
  CHANGELOG_URL,
  LICENSE_URL,
  CONTRIBUTING_URL,
  JJ_URL,
  SUPPORT_EMAIL,
  VERSION,
} from "../config";
---

<footer class="footer">
  <div class="container cta-band">
    <h2>Ready to try Jiji?</h2>
    <p>Free, native, and notarized. Bring your own jj repo.</p>
    <a class="btn btn-primary" href={DOWNLOAD_URL}>Download for macOS</a>
    <p class="meta-line">
      macOS <span class="dot">·</span> v{VERSION}
      <span class="dot">·</span>
      <a href={RELEASES_URL} rel="noopener">release notes</a>
    </p>
  </div>

  <div class="container foot-grid">
    <div class="foot-brand">
      <Logo href={null} />
      <p>A desktop workbench for Jujutsu.</p>
    </div>

    <nav aria-label="Product">
      <h4>Product</h4>
      <a href="#features">Features</a>
      <a href="#themes">Themes</a>
      <a href="#pricing">Pricing</a>
      <a href={DOWNLOAD_URL}>Download</a>
    </nav>

    <nav aria-label="Source">
      <h4>Source</h4>
      <a href={GITHUB_URL} rel="noopener">GitHub</a>
      <a href={CHANGELOG_URL} rel="noopener">Changelog</a>
      <a href={CONTRIBUTING_URL} rel="noopener">Contributing</a>
      <a href={LICENSE_URL} rel="noopener">License</a>
    </nav>

    <nav aria-label="More">
      <h4>More</h4>
      <a href={`mailto:${SUPPORT_EMAIL}`}>Support</a>
      <a href={JJ_URL} rel="noopener">What is jj?</a>
    </nav>
  </div>

  <div class="container foot-base">
    <span>© 2026 Jiji</span>
    <span>Built with jj · Source-available under FSL-1.1-MIT</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--clr-border-2);
    background: var(--clr-bg-1);
  }

  .cta-band {
    text-align: center;
    padding-block: clamp(64px, 9vw, 104px);
  }

  .cta-band h2 {
    font-size: var(--fs-h2);
  }

  .cta-band p {
    margin-top: var(--sp-3);
    color: var(--clr-text-2);
    font-size: var(--fs-lead);
  }

  .cta-band .btn {
    margin-top: var(--sp-5);
  }

  .cta-band .meta-line {
    margin-top: var(--sp-4);
  }

  .cta-band .meta-line a {
    color: var(--clr-accent-strong);
  }

  .cta-band .meta-line a:hover {
    text-decoration: underline;
  }

  .foot-grid {
    display: grid;
    grid-template-columns: 1.6fr repeat(3, 1fr);
    gap: var(--sp-6);
    padding-block: var(--sp-8);
    border-top: 1px solid var(--clr-border-2);
  }

  .foot-brand p {
    margin-top: var(--sp-3);
    color: var(--clr-text-3);
    font-size: var(--fs-small);
    max-width: 28ch;
  }

  nav h4 {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--clr-text-3);
    margin-bottom: var(--sp-3);
  }

  nav a {
    display: block;
    padding: var(--sp-1) 0;
    color: var(--clr-text-2);
    font-size: 0.95rem;
    transition: color var(--t-fast) var(--ease-out);
  }

  nav a:hover {
    color: var(--clr-text-1);
  }

  .foot-base {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
    justify-content: space-between;
    padding-block: var(--sp-5);
    border-top: 1px solid var(--clr-border-2);
    color: var(--clr-text-3);
    font-size: var(--fs-small);
  }

  @media (max-width: 640px) {
    .foot-grid {
      grid-template-columns: 1fr 1fr;
    }
    .foot-brand {
      grid-column: 1 / -1;
    }
  }
</style>
