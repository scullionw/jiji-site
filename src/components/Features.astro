---
const features = [
  {
    title: "The graph, first",
    body: "A dense, jj-native log graph: your working stack runs hot, sibling stacks stay calm, trunk sits in context. If you know the CLI's tree output, you already know this.",
    icon: "graph",
  },
  {
    title: "Diffs you live in",
    body: "A continuous, multi-file, syntax-highlighted diff — built to be a daily destination, not a utility pane. Jump file to file without losing your place.",
    icon: "diff",
  },
  {
    title: "Rewrite, directly",
    body: "describe, new, edit, squash, abandon, move, rebase — as direct actions. Every risky change shows you what it will rewrite before it happens.",
    icon: "edit",
  },
  {
    title: "Bookmarks, managed",
    body: "Create, move, rename, and delete bookmarks straight from the graph, without dropping back to the terminal.",
    icon: "bookmark",
  },
  {
    title: "Undo is a habit",
    body: "Every operation lands on a timeline you can restore or revert with one click. jj's recoverability, finally visible.",
    icon: "history",
  },
  {
    title: "Native macOS",
    body: "A small, fast Tauri app — signed, notarized, and auto-updating. It feels like a Mac app because it is one.",
    icon: "mac",
  },
];

const icons: Record<string, string> = {
  graph:
    '<circle cx="6" cy="5" r="2"/><circle cx="6" cy="15" r="2"/><circle cx="15" cy="10" r="2"/><path d="M6 7v6M7.6 14l5.6-3"/>',
  diff: '<path d="M4 4h12M4 8h7M4 12h12M4 16h7"/><path d="M16 14v4M14 16h4"/>',
  edit: '<path d="M3 14.5V17h2.5L14 8.5 11.5 6 3 14.5z"/><path d="M11.5 6 14 8.5"/>',
  bookmark: '<path d="M6 3h8v14l-4-3-4 3V3z"/>',
  history:
    '<path d="M3.5 10a6.5 6.5 0 1 1 1.9 4.6"/><path d="M3.5 14v-4h4"/><path d="M10 6.5V10l2.5 1.5"/>',
  mac: '<rect x="3" y="4" width="14" height="9" rx="1.5"/><path d="M7 17h6M9 13v4M11 13v4"/>',
};
---

<section class="section features" id="features">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Built for jj</p>
      <h2>JJ-native, not Git-shaped.</h2>
      <p>
        Jiji favors the working-copy commit, bookmarks, revsets, and the
        operation log — not staged files and branches. Here's what's real
        today.
      </p>
    </div>

    <div class="grid">
      {
        features.map((f) => (
          <article class="card">
            <span class="ic">
              <svg viewBox="0 0 20 20" aria-hidden="true" set:html={icons[f.icon]} />
            </span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>

    <p class="roadmap">
      <span class="rk">On the way</span>
      A conflict inbox, stacked-PR publishing, land &amp; ship-to-trunk flows,
      and local auto-land. Jiji is alpha and moving quickly.
    </p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--sp-4);
  }

  .card {
    padding: var(--sp-6);
    background: var(--clr-bg-1);
    border: 1px solid var(--clr-border-2);
    border-radius: var(--radius-l);
    transition:
      border-color var(--t-med) var(--ease-out),
      transform var(--t-med) var(--ease-out);
  }

  .card:hover {
    border-color: var(--clr-border-1);
    transform: translateY(-2px);
  }

  .ic {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-m);
    background: var(--clr-accent-dim);
    margin-bottom: var(--sp-4);
  }

  .ic svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: var(--clr-accent-strong);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  h3 {
    font-size: var(--fs-h3);
    margin-bottom: var(--sp-2);
  }

  .card p {
    color: var(--clr-text-2);
    font-size: 0.98rem;
  }

  .roadmap {
    margin-top: var(--sp-6);
    padding: var(--sp-4) var(--sp-5);
    background: var(--clr-bg-1);
    border: 1px dashed var(--clr-border-1);
    border-radius: var(--radius-l);
    color: var(--clr-text-2);
    font-size: 0.98rem;
  }

  .rk {
    display: inline-block;
    margin-right: var(--sp-2);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--clr-accent-strong);
  }
</style>
