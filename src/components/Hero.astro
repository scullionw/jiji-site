---
import WorkbenchMock from "./WorkbenchMock.astro";
import { DOWNLOAD_URL, GITHUB_URL, VERSION } from "../config";
---

<section class="hero">
  <div class="container hero-inner">
    <p class="eyebrow">
      <svg class="motif" viewBox="0 0 40 14" width="40" height="14" aria-hidden="true">
        <path d="M4 7 H14" />
        <path d="M14 7 Q20 1 26 7" />
        <path d="M26 7 H36" />
        <circle cx="4" cy="7" r="2.4" style="fill: var(--clr-working-copy)" />
        <circle cx="14" cy="7" r="2.4" style="fill: var(--clr-accent)" />
        <circle cx="26" cy="7" r="2.4" style="fill: var(--clr-accent-strong)" />
        <circle cx="36" cy="7" r="2.4" style="fill: var(--clr-danger)" />
      </svg>
      Alpha · macOS
    </p>

    <h1>The desktop workbench<br /> for Jujutsu.</h1>

    <p class="lead">
      Jiji turns <span class="mono">jj</span>'s best ideas — the working-copy
      commit, the log graph, and the operation log — into a fast, native macOS
      app you can live in. Read the graph, review diffs, and rewrite history
      with confidence.
    </p>

    <div class="cta">
      <a class="btn btn-primary" href={DOWNLOAD_URL}>
        <svg viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path d="M11.18 8.49c-.02-1.7 1.39-2.51 1.45-2.55-.79-1.16-2.02-1.32-2.46-1.34-1.05-.11-2.04.62-2.57.62-.53 0-1.34-.6-2.2-.59-1.13.02-2.18.66-2.76 1.67-1.18 2.04-.3 5.07.85 6.73.56.81 1.23 1.72 2.1 1.69.84-.03 1.16-.54 2.18-.54 1.02 0 1.3.54 2.19.53.9-.02 1.48-.83 2.03-1.65.64-.94.9-1.86.92-1.9-.02-.01-1.77-.68-1.79-2.7zM9.5 3.6c.47-.57.79-1.36.7-2.15-.68.03-1.5.45-1.98 1.02-.43.5-.81 1.3-.71 2.07.76.06 1.53-.39 1.99-.94z"/></svg>
        Download for macOS
      </a>
      <a class="btn btn-ghost" href={GITHUB_URL} rel="noopener">
        <svg viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View source
      </a>
    </div>

    <p class="meta-line">
      Free <span class="dot">·</span> Universal (Apple Silicon &amp; Intel)
      <span class="dot">·</span> Notarized <span class="dot">·</span> v{VERSION}
    </p>
  </div>

  <div class="container showcase">
    <WorkbenchMock />
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(56px, 9vw, 104px);
    overflow: hidden;
  }

  /* Soft accent aurora behind the hero. */
  .hero::before {
    content: "";
    position: absolute;
    top: -180px;
    left: 50%;
    width: min(1100px, 120vw);
    height: 560px;
    translate: -50% 0;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--clr-accent) 22%, transparent),
      transparent 62%
    );
    filter: blur(20px);
    opacity: 0.7;
    pointer-events: none;
    z-index: -1;
  }

  .hero-inner {
    text-align: center;
    max-width: 800px;
  }

  .eyebrow .motif path {
    fill: none;
    stroke: color-mix(in srgb, var(--clr-accent) 60%, var(--clr-text-3));
    stroke-width: 1.5;
  }

  h1 {
    margin-top: var(--sp-4);
    font-size: var(--fs-display);
    font-weight: 680;
  }

  .lead {
    margin: var(--sp-5) auto 0;
    max-width: 620px;
    font-size: var(--fs-lead);
    color: var(--clr-text-2);
  }

  .cta {
    margin-top: clamp(28px, 4vw, 40px);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
  }

  .meta-line {
    margin-top: var(--sp-4);
  }

  .showcase {
    margin-top: clamp(48px, 7vw, 80px);
    max-width: 1040px;
    perspective: 1600px;
  }

  .showcase :global(.win) {
    transform: rotateX(2deg);
    transform-origin: center top;
  }
</style>
